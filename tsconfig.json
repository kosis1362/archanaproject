{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ]
}